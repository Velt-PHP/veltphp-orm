{
  "name": "velt/orm",
  "description": "Active record ORM layer for the Velt framework.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "velt/database": "^0.1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Velt\\Orm\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Velt\\Orm\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "phpunit --colors=always"
  }
}
